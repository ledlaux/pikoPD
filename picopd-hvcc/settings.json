{
  "name": "heavy",
  "pico_board": "pico2",
  "core_freq": "200000",
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "sample_rate": 32000,
  "max_voices": 3,
  "channel": 2,
  "buffer_size": 64,
  
  "adc_pins": [
    { "name": "knob", "pin": 26, "type": "knob" },
    { "name": "pot", "pin": 27, "type": "knob" },
    { "name": "cv1", "pin": 28, "type": "cv_in" },
    { "name": "cv2", "pin": 29, "type": "cv_in" }
  ],

  "buttons": [
    { "name": "btn1", "pin": 12, "mode": "switch" },
    { "name": "btn2", "pin": 13, "mode": "switch" },
    { "name": "hat", "pin": 14, "mode": "toggle" }
  ],

  "leds": [
    { "name": "gate_t", "pin": 24 },
    { "name": "led2", "pin": 25 }
  ],
  "gate_in": [
    { "name": "gate_in", "pin": 15 },
  ],
  "gate_out": [
    { "name": "gate_out", "pin": 1 },
  ]
  
}
