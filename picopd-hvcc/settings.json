{
  "name": "heavy",
  "pico_board": "pico2",
  "core_freq": "200000",
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "sample_rate": 32000,
  "max_voices": 3,
  "channel": 2,
  "buffer_size": 64,
  
  "adc_pins": [
    { "name": "knob", "pin": 26, "type": "knob" },
    { "name": "pot", "pin": 27, "type": "knob" }
  ],

  "buttons": [
    { "name": "btn1", "pin": 12 , "mode": "bang" },
    { "name": "btn2", "pin": 13, "mode": "toggle" },
    { "name": "btn3", "pin": 14, "mode": "switch" }
  ],

  "leds": [
    { "name": "led1", "pin": 24 },
    { "name": "led2", "pin": 25 }
  ]

}
