{
  "name": "heavy",
  "pico_board": "pico_w",
  "core_freq": "200000",
  "audio_mode": "I2S",
  "sample_rate": 48000,
  "max_voices": 3,
  "channel": 2,
  "buffer_size": 32,
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "pwm_pin_l": 2,
  "pwm_pin_r": 3,
  "adc_pins": [
    { "name": "knob", "pin": 26, "type": "knob" },
    { "name": "pot", "pin": 27, "type": "knob" },
    { "name": "cv1", "pin": 28, "type": "cv_in" },
    { "name": "cv2", "pin": 29, "type": "cv_in" }
  ],

  "buttons": [
    { "name": "btn1", "pin": 1, "mode": "switch" },
    { "name": "btn2", "pin": 13, "mode": "toggle" },
    { "name": "btn3", "pin": 14, "mode": "bang" }
  ],

  "leds": [
    { "name": "led1", "pin": 24 },
    { "name": "led2", "pin": 25 }
  ],

  "gate_in": [
    { "name": "gate_in", "pin": 15 }
  ],

  "gate_out": [
    { "name": "kick", "pin": 3, "mode": "trigger" },
    { "name": "vca", "pin": 2, "mode": "gate" }
  ],

  "encoders": [
    { "name": "enc", "pin_a": 4, "pin_b": 5 }
  ],

  "joystick": [ 
    {"name": "joy", "joy_x": 26, "joy_y": 27, "midi_range": true}
  ]


}