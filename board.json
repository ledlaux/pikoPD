{
  "name": "heavy",
  "pico_board": "pico_w",
  "core_freq": 240000,
  "audio_mode": "I2S",
  "sample_rate": 48000,
  "channel": 2,
  "buffer_size": 64,
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "pwm_pin": 10,
  "voice_count": 1,
  "midi_mode": "usb",
  "console": true,

  "inputs": {
    "adc_pins": [
      { "name": "knob", "pin": 26, "type": "knob" }
    ],

    "buttons": [
      { "name": "btn1", "pin": 23, "mode": "switch" },
      { "name": "btn3", "pin": 14, "mode": "bang" }
    ],

    "gate_in": [
    ],

    "encoders": [
    ],

    "joystick": [
    ],

     "sensors": {
      "cny70": [
      ],
       "mpr121": [
      ],
       "hc-sr04": [
        { "name": "distance", "trigger": 2, "echo": 3}
      ]
    }
  },

  "outputs": {
    
    "gate_out": [
    ]
  },

  "leds": [
    { "name": "led1", "pin": 25, "mode": "pd" }
  ], 

  "masterfx": {
    "limiter": true,
    "delay": false
  }
}
