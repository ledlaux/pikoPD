
{
  "name": "heavy",
  "pico_board": "pico2",
  "core_freq": 240000,
  "audio_mode": "I2S",
  "sample_rate": 48000,
  "channel": 2,
  "buffer_size": 64,
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "pwm_pin": 10,
  "midi_mode": "usb",
  "console": false,

  "inputs": {

    "adc_pins": [
      { "name": "knob", "pin": 26, "type": "knob" },
      { "name": "pot", "pin": 27, "type": "knob" },
      { "name": "cv1", "pin": 28, "type": "cv_in" }
    ],

    "buttons": [
      { "name": "btn1", "pin": 23, "mode": "switch" },
      { "name": "btn2", "pin": 11, "mode": "switch" },
      { "name": "btn3", "pin": 14, "mode": "bang" }
    ],

    "gate_in": [
      { "name": "gate_in", "pin": 15 }
    ],

    "encoders": [
      { "name": "enc", "pin_a": 5, "pin_b": 6 }
    ],

    "joystick": [
      { "name": "joy", "joy_x": 26, "joy_y": 27, "midi_range": true }
    ]
  },

  "outputs": {
    
    "gate_out": [
      { "name": "gate", "pin": 2, "mode": "gate" },
      { "name": "trigger", "pin": 3, "mode": "trigger" }
    ]
  },

  "leds": [
    { "name": "ledRGB", "pin": 16, "is_rgb": true, "mode": "pd" },
    { "name": "led1", "pin": 25, "mode": "pd" },
    { "name": "midi", "pin": 24, "mode": "midi" },
    { "name": "clock", "pin": 23, "mode": "clock" }
   
  ], 

  "masterfx": {
    "limiter": true,
    "delay": false
  }
}
