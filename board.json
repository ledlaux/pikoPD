
{
  "name": "heavy",
  "pico_board": "zero",
  "core_freq": 240000,
  "audio_mode": "I2S",
  "sample_rate": 48000,
  "max_voices": 3,
  "channel": 2,
  "buffer_size": 32,
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "midi_mode": "usb",

  "inputs": {

    "adc_pins": [
      { "name": "knob", "pin": 26, "type": "knob" },
      { "name": "cv1", "pin": 27, "type": "cv_in" }
    ],

    "buttons": [
      { "name": "btn1", "pin": 23, "mode": "switch" },
      { "name": "btn2", "pin": 11, "mode": "toggle" },
      { "name": "btn3", "pin": 14, "mode": "bang" }
    ],

    "gate_in": [
      { "name": "gate_in", "pin": 15 }
    ],

    "encoders": [
      { "name": "enc", "pin_a": 5, "pin_b": 6 }
    ],

    "joystick": [
      { "name": "joy", "joy_x": 28, "joy_y": 29, "midi_range": true }
    ]
  },

  "outputs": {
    
    "gate_out": [
      { "name": "gate", "pin": 2, "mode": "gate" },
      { "name": "trigger", "pin": 3, "mode": "trigger" }
    ]
  },

  "leds": [
    { "name": "led1", "pin": 25, "mode": "pd" },
    { "name": "status", "pin": 7, "mode": "status" },
    { "name": "ledRGB", "pin": 16, "is_rgb": true, "mode": "midi" }
  ]
}
