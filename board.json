{
  "name": "heavy",
  "pico_board": "pico_w",
  "core_freq": 240000,
  "audio_mode": "I2S",
  "sample_rate": 22050,
  "channel": 2,
  "buffer_size": 64,
  "i2s_data_pin": 9,
  "i2s_bclk_pin": 10,
  "pwm_pin": 10,
  "voice_count": 1,
  "midi_mode": "usb",
  "console": true,

  "inputs": {

    "adc_pins": [
      { "name": "knob", "pin": 26, "type": "knob" },
      { "name": "pot", "pin": 27, "type": "knob" },
      { "name": "cv1", "pin": 28, "type": "cv_in" }
    ],

    "buttons": [
      { "name": "btn1", "pin": 23, "mode": "switch" },
      { "name": "btn2", "pin": 11, "mode": "switch" },
      { "name": "btn3", "pin": 14, "mode": "bang" }
    ],

    "gate_in": [
      { "name": "gate_in", "pin": 15 }
    ],

    "encoders": [
      { "name": "enc", "pin_a": 14, "pin_b": 15 }
    ],

    "joystick": [
      { "name": "joy", "joy_x": 26, "joy_y": 27, "midi_range": true }
    ],

  "sensors": {
       
      "cny70": [
      
      ],
       
       "mpr121": [       
        { "name": "mpr1", "i2c_bus": "i2c0", "sda": 4, "scl": 5, "irq": 3, "addr_index": 0 }
      ],
       
       "hc-sr04": [
    
      ]
    }
  },

  "outputs": {
    
    "gate_out": [
      { "name": "gate", "pin": 2, "mode": "gate" },
      { "name": "trigger", "pin": 3, "mode": "trigger" }
    ]
  },

  "leds": [
   
   
  ], 
  
  "masterfx": {
    "delay": false,
    "reverb": false,
    "limiter": true
  },


 "web": {
